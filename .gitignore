# Data — personal, never committed (versionado via DVC)
# Subpastas grandes sao trackadas individualmente; DVC gera .gitignore proprio
# em cada nivel pra ignorar so o conteudo trackado (README e similares ficam
# no git). Ver docs/dvc-runbook.md.
data/raw/
data/merged/
data/processed/
data/unified/

# Python
__pycache__/
*.pyc
.venv/
*.egg-info/
dist/
build/
.coverage
.pytest_cache/

# IDE
.vscode/
.idea/

# Quarto
.quarto/
*_files/
*.html
notebooks/_output/

# Streamlit static (HTMLs do Quarto copiados pra serving)
static/quarto/

# Positron / Playwright storage
.storage/

# OS
.DS_Store

# Media (screencasts, recordings)
*.mov
*.mp4

# R
.Rhistory

# Backups
*.bak
_backup-temp/

# Local scratch
local/
.tmp/

# Local-only docs (planos internos, journeys, housekeeping, superpowers).
# Conteudo util pra contributor externo foi extraido pros docs publicos
# (CONTRIBUTING.md, LIMITATIONS.md, docs/probes/).
docs/local/

# Servidor HTTP local (scripts/serve-qmds.sh)
.serve-qmds.pid
.serve-qmds.log

# Streamlit dashboard (background)
.streamlit-dashboard.pid
.streamlit-dashboard.log

# Render batch helper
.render-all.pid
